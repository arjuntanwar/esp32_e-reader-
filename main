// ================= FIXED TIME CONVERSION FUNCTIONS =================
void convertUnixToTime(unsigned long unixTime) {
  // Add IST offset (5 hours 30 minutes = 19800 seconds)
  unsigned long localTime = unixTime + 19800;
  
  // Extract time components
  seconds = localTime % 60;
  unsigned long totalMinutes = localTime / 60;
  minutes = totalMinutes % 60;
  unsigned long totalHours = totalMinutes / 60;
  hours = totalHours % 24;
  
  // Calculate days since epoch
  unsigned long days = totalHours / 24;
  
  // Unix epoch started on Jan 1, 1970
  // Start calculation from 1970
  year = 1970;
  
  while (days >= 365) {
    int daysInYear = ((year % 4 == 0 && year % 100 != 0) || (year % 400 == 0)) ? 366 : 365;
    if (days >= daysInYear) {
      days -= daysInYear;
      year++;
    } else {
      break;
    }
  }
  
  month = 1;
  while (true) {
    int daysInMonth = getDaysInMonth(month, year);
    if (days >= daysInMonth) {
      days -= daysInMonth;
      month++;
    } else {
      break;
    }
  }
  
  day = days + 1;
  
  // Calculate day of week (Jan 1, 1970 was Thursday = 4)
  // 0 = Sunday, 1 = Monday, 2 = Tuesday, 3 = Wednesday, 4 = Thursday, 5 = Friday, 6 = Saturday
  unsigned long totalDaysSince1970 = (totalHours / 24);
  weekDay = (4 + totalDaysSince1970) % 7;
}

void updateTimeFromUnix() {
  convertUnixToTime(rtc_unixTime);
}

// ================= SETUP =================
void setup() {
  Serial.begin(115200);
  rtc_bootCount++;
  Serial.println("ESP32-C3 Smart Watch - Boot #" + String(rtc_bootCount));
  
  pinMode(BTN_UP, INPUT_PULLUP);
  pinMode(BTN_DOWN, INPUT_PULLUP);
  pinMode(BTN_SELECT, INPUT_PULLUP);
  pinMode(BTN_BACK, INPUT_PULLUP);
  pinMode(OLED_POWER_PIN, OUTPUT);
  digitalWrite(OLED_POWER_PIN, HIGH);
  
  Wire.begin(SDA_PIN, SCL_PIN);
  display.begin(SSD1306_SWITCHCAPVCC, SCREEN_ADDRESS);
  display.setRotation(2);
  display.setTextColor(WHITE);
  display.ssd1306_command(SSD1306_SETCONTRAST);
  display.ssd1306_command(brightness);
  
  loadTimeFromRTC();
  
  if (!SPIFFS.begin(true)) {
    Serial.println("SPIFFS mount failed");
  } else {
    if (!SPIFFS.exists("/chapters.json")) {
      addChapter("Getting Started");
      addChapter("User Guide");
      addChapter("Advanced");
    }
    loadChapters();
  }
  
  display.clearDisplay();
  display.setCursor(25, 20);
  display.println("SMART");
  display.setCursor(20, 40);
  display.println("WATCH");
  display.display();
  delay(1000);
  
  lastActivityTime = millis();
  lastTick = millis();
  updateTimeFromUnix();
  displayWatchFace();
}

void loadTimeFromRTC() {
  if (rtc_timeSet && rtc_unixTime > 0) {
    convertUnixToTime(rtc_unixTime);
    Serial.printf("Time loaded from RTC: %02d:%02d:%02d %02d/%02d/%04d (Unix: %lu)\n", 
                  hours, minutes, seconds, day, month, year, rtc_unixTime);
  } else {
    Serial.println("No time in RTC, will sync with WiFi");
    rtc_unixTime = 0;
  }
}

void saveTimeToRTC() {
  rtc_unixTime = getCurrentUnixTime();
  rtc_timeSet = true;
  Serial.printf("Time saved to RTC: %lu\n", rtc_unixTime);
}

unsigned long getCurrentUnixTime() {
  return rtc_unixTime + ((millis() - lastTick) / 1000);
}

// ================= TIME SYNC FUNCTION =================
void syncTimeWithWiFi() {
  Mode previousMode = currentMode;
  currentMode = MODE_TIME_SYNC;
  
  display.clearDisplay();
  display.setCursor(10, 15);
  display.println("Sync Time");
  display.drawLine(0, 25, 128, 25, WHITE);
  display.setCursor(10, 38);
  display.println("Connecting to WiFi...");
  display.display();
  
  WiFi.mode(WIFI_STA);
  WiFi.begin(wifi_ssid, wifi_password);
  
  int attempts = 0;
  
  while (WiFi.status() != WL_CONNECTED && attempts < 30) {
    delay(500);
    attempts++;
    display.clearDisplay();
    display.setCursor(10, 15);
    display.println("Sync Time");
    display.drawLine(0, 25, 128, 25, WHITE);
    display.setCursor(10, 38);
    display.print("Connecting");
    for (int i = 0; i < (attempts / 3); i++) display.print(".");
    display.display();
  }
  
  if (WiFi.status() == WL_CONNECTED) {
    display.clearDisplay();
    display.setCursor(10, 15);
    display.println("Sync Time");
    display.drawLine(0, 25, 128, 25, WHITE);
    display.setCursor(10, 38);
    display.println("Getting time from NTP...");
    display.display();
    
    configTime(gmtOffset_sec, daylightOffset_sec, ntpServer);
    
    struct tm timeinfo;
    int syncAttempts = 0;
    
    while (!getLocalTime(&timeinfo) && syncAttempts < 20) {
      delay(500);
      syncAttempts++;
      display.clearDisplay();
      display.setCursor(10, 15);
      display.println("Sync Time");
      display.drawLine(0, 25, 128, 25, WHITE);
      display.setCursor(10, 38);
      display.print("Getting time");
      for (int i = 0; i < (syncAttempts / 3); i++) display.print(".");
      display.display();
    }
    
    if (syncAttempts < 20) {
      // Convert tm structure to Unix timestamp
      time_t utcTime = mktime(&timeinfo);
      rtc_unixTime = utcTime;
      rtc_timeSet = true;
      
      updateTimeFromUnix();
      
      display.clearDisplay();
      display.setCursor(10, 15);
      display.println("Sync Time");
      display.drawLine(0, 25, 128, 25, WHITE);
      display.setCursor(20, 38);
      display.println("SUCCESS!");
      display.setCursor(10, 52);
      char timeStr[20];
      sprintf(timeStr, "%02d:%02d:%02d", hours, minutes, seconds);
      display.println(timeStr);
      display.display();
      delay(2000);
      
      Serial.printf("Time synced: %02d:%02d:%02d %02d/%02d/%04d\n", 
                    hours, minutes, seconds, day, month, year);
    } else {
      display.clearDisplay();
      display.setCursor(10, 15);
      display.println("Sync Time");
      display.drawLine(0, 25, 128, 25, WHITE);
      display.setCursor(10, 38);
      display.println("NTP Timeout!");
      display.display();
      delay(2000);
    }
    
    WiFi.disconnect(true);
    WiFi.mode(WIFI_OFF);
  } else {
    display.clearDisplay();
    display.setCursor(10, 15);
    display.println("Sync Time");
    display.drawLine(0, 25, 128, 25, WHITE);
    display.setCursor(10, 38);
    display.println("WiFi Failed!");
    display.display();
    delay(2000);
  }
  
  currentMode = previousMode;
  lastTick = millis();
  
  if (currentMode == MODE_WATCH) {
    displayWatchFace();
  } else if (currentMode == MODE_READER) {
    displayMenu();
  }
}

// ================= TIME COUNTER =================
void updateTimeCounter() {
  unsigned long now = millis();
  if (now - lastTick >= 1000) {
    lastTick = now;
    rtc_unixTime++;
    updateTimeFromUnix();
    
    if (currentMode == MODE_WATCH) {
      displayWatchFace();
    }
  }
}

int getDaysInMonth(int month, int year) {
  if (month == 2) {
    if ((year % 4 == 0 && year % 100 != 0) || (year % 400 == 0)) return 29;
    return 28;
  }
  if (month == 4 || month == 6 || month == 9 || month == 11) return 30;
  return 31;
}

// ================= FILE MANAGEMENT =================
void loadChapters() {
  File file = SPIFFS.open("/chapters.json", FILE_READ);
  if (!file) return;
  
  DynamicJsonDocument doc(2048);
  deserializeJson(doc, file);
  JsonArray arr = doc.as<JsonArray>();
  chapterCount = 0;
  for (JsonVariant v : arr) {
    if (chapterCount < MAX_CHAPTERS) chapters[chapterCount++] = v.as<String>();
  }
  file.close();
}

void saveChapters() {
  DynamicJsonDocument doc(2048);
  JsonArray arr = doc.to<JsonArray>();
  for (int i = 0; i < chapterCount; i++) arr.add(chapters[i]);
  
  File file = SPIFFS.open("/chapters.json", FILE_WRITE);
  serializeJson(doc, file);
  file.close();
}

void loadTopics(int ch) {
  String path = "/ch" + String(ch + 1) + ".json";
  File file = SPIFFS.open(path, FILE_READ);
  topicCount = 0;
  if (!file) return;
  
  DynamicJsonDocument doc(2048);
  deserializeJson(doc, file);
  JsonArray arr = doc.as<JsonArray>();
  for (JsonVariant v : arr) {
    if (topicCount < MAX_TOPICS) topics[topicCount++] = v.as<String>();
  }
  file.close();
}

void saveTopics(int ch) {
  String path = "/ch" + String(ch + 1) + ".json";
  DynamicJsonDocument doc(2048);
  JsonArray arr = doc.to<JsonArray>();
  for (int i = 0; i < topicCount; i++) arr.add(topics[i]);
  
  File file = SPIFFS.open(path, FILE_WRITE);
  serializeJson(doc, file);
  file.close();
}

void loadContent(int ch, int topic) {
  String path = "/ch" + String(ch + 1) + "_" + String(topic + 1) + ".txt";
  File file = SPIFFS.open(path, FILE_READ);
  lineCount = 0;
  
  if (!file) {
    textLines[lineCount++] = "No content";
    return;
  }
  
  while (file.available() && lineCount < MAX_LINES) {
    String line = file.readStringUntil('\n');
    line.trim();
    while (line.length() > 21 && lineCount < MAX_LINES) {
      int wrap = 21;
      for (int i = 21; i > 15; i--) {
        if (i < line.length() && line.charAt(i) == ' ') {
          wrap = i;
          break;
        }
      }
      textLines[lineCount++] = line.substring(0, wrap);
      line = line.substring(wrap);
      line.trim();
    }
    if (line.length() > 0 && lineCount < MAX_LINES) {
      textLines[lineCount++] = line;
    }
  }
  file.close();
}

bool saveContent(int ch, int topic, String content) {
  String path = "/ch" + String(ch + 1) + "_" + String(topic + 1) + ".txt";
  File file = SPIFFS.open(path, FILE_WRITE);
  if (!file) return false;
  file.print(content);
  file.close();
  return true;
}

void addChapter(String name) {
  if (chapterCount >= MAX_CHAPTERS) return;
  chapters[chapterCount++] = name;
  saveChapters();
  
  topicCount = 0;
  for (int i = 1; i <= 3; i++) {
    topics[topicCount++] = "Topic " + String(i);
  }
  saveTopics(chapterCount - 1);
  
  for (int i = 0; i < topicCount; i++) {
    saveContent(chapterCount - 1, i, "Content for " + name + " - " + topics[i] + "\n\nEdit this via WiFi.");
  }
}

void deleteChapter(int ch) {
  if (ch < 0 || ch >= chapterCount) return;
  
  for (int i = ch; i < chapterCount - 1; i++) {
    chapters[i] = chapters[i + 1];
    for (int t = 0; t < MAX_TOPICS; t++) {
      String oldPath = "/ch" + String(i + 2) + "_" + String(t + 1) + ".txt";
      String newPath = "/ch" + String(i + 1) + "_" + String(t + 1) + ".txt";
      if (SPIFFS.exists(oldPath)) {
        File f = SPIFFS.open(oldPath, FILE_READ);
        String content = f.readString();
        f.close();
        File wf = SPIFFS.open(newPath, FILE_WRITE);
        wf.print(content);
        wf.close();
        SPIFFS.remove(oldPath);
      }
    }
    String oldTopic = "/ch" + String(i + 2) + ".json";
    String newTopic = "/ch" + String(i + 1) + ".json";
    if (SPIFFS.exists(oldTopic)) SPIFFS.rename(oldTopic, newTopic);
  }
  chapterCount--;
  saveChapters();
}

void addTopic(int ch, String name) {
  if (ch < 0 || ch >= chapterCount) return;
  loadTopics(ch);
  if (topicCount >= MAX_TOPICS) return;
  topics[topicCount++] = name;
  saveTopics(ch);
  saveContent(ch, topicCount - 1, "Content for " + chapters[ch] + " - " + name + "\n\nEdit this via WiFi.");
}

void deleteTopic(int ch, int topic) {
  if (ch < 0 || ch >= chapterCount) return;
  loadTopics(ch);
  if (topic < 0 || topic >= topicCount) return;
  
  for (int i = topic; i < topicCount - 1; i++) {
    topics[i] = topics[i + 1];
    String oldPath = "/ch" + String(ch + 1) + "_" + String(i + 2) + ".txt";
    String newPath = "/ch" + String(ch + 1) + "_" + String(i + 1) + ".txt";
    if (SPIFFS.exists(oldPath)) {
      File f = SPIFFS.open(oldPath, FILE_READ);
      String content = f.readString();
      f.close();
      File wf = SPIFFS.open(newPath, FILE_WRITE);
      wf.print(content);
      wf.close();
      SPIFFS.remove(oldPath);
    }
  }
  topicCount--;
  saveTopics(ch);
}

void renameChapter(int ch, String name) {
  if (ch >= 0 && ch < chapterCount) {
    chapters[ch] = name;
    saveChapters();
  }
}

void renameTopic(int ch, int topic, String name) {
  loadTopics(ch);
  if (topic >= 0 && topic < topicCount) {
    topics[topic] = name;
    saveTopics(ch);
  }
}

// ================= WEB SERVER =================
void setupAPMode() {
  if (apEnabled) return;
  WiFi.mode(WIFI_AP);
  WiFi.softAP(ap_ssid, ap_password);
  apEnabled = true;
  setupWebServer();
  showMessage("AP Mode: FPV_CAM");
}

void stopAPMode() {
  if (!apEnabled) return;
  WiFi.softAPdisconnect(true);
  apEnabled = false;
}

void setupWebServer() {
  server.on("/", []() {
    String html = "<!DOCTYPE html><html>";
    html += "<head><meta name='viewport' content='width=device-width, initial-scale=1'>";
    html += "<title>E-Reader Manager</title>";
    html += "<style>";
    html += "body{font-family:Arial;background:#1a1a2e;margin:0;padding:20px;color:#eee}";
    html += ".container{max-width:800px;margin:auto}";
    html += ".card{background:#16213e;border-radius:10px;padding:20px;margin-bottom:20px}";
    html += "button{background:#e94560;color:white;padding:8px 15px;border:none;border-radius:5px;cursor:pointer;margin:5px}";
    html += "button:hover{opacity:0.8}";
    html += ".btn-green{background:#4CAF50}";
    html += ".btn-blue{background:#2196F3}";
    html += ".btn-orange{background:#ff9800}";
    html += ".btn-red{background:#f44336}";
