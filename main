    html += "function renameChapterSubmit(){let n=document.getElementById('rcName').value;fetch('/api/rename_chapter',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({chapter:chapterIdx,name:n})}).then(()=>location.reload());}";
    html += "function renameTopicSubmit(){let n=document.getElementById('rtName').value;fetch('/api/rename_topic',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({chapter:chapterIdx,topic:topicIdx,name:n})}).then(()=>location.reload());}";
