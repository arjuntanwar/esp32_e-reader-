        html += "</div>";
      }
      html += "</div>";
    }
    
    html += "</div>";
    
    html += "<div id='addChapterModal' class='modal'><div class='modal-content'><h3>Add Chapter</h3><input id='chName' placeholder='Chapter name'><br><button class='btn-green' onclick='addChapter()'>Create</button><button onclick='closeModal()'>Cancel</button></div></div>";
    html += "<div id='addTopicModal' class='modal'><div class='modal-content'><h3>Add Topic</h3><input id='tpName' placeholder='Topic name'><br><button class='btn-green' onclick='addTopic()'>Create</button><button onclick='closeModal()'>Cancel</button></div></div>";
    html += "<div id='renameChapterModal' class='modal'><div class='modal-content'><h3>Rename Chapter</h3><input id='rcName'><br><button class='btn-orange' onclick='renameChapterSubmit()'>Rename</button><button onclick='closeModal()'>Cancel</button></div></div>";
    html += "<div id='renameTopicModal' class='modal'><div class='modal-content'><h3>Rename Topic</h3><input id='rtName'><br><button class='btn-orange' onclick='renameTopicSubmit()'>Rename</button><button onclick='closeModal()'>Cancel</button></div></div>";
    
    html += "<script>";
