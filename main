    html += ".container{max-width:800px;margin:auto}";
    html += ".card{background:#16213e;border-radius:10px;padding:20px;margin-bottom:20px}";
    html += "button{background:#e94560;color:white;padding:8px 15px;border:none;border-radius:5px;cursor:pointer;margin:5px}";
    html += "button:hover{opacity:0.8}";
    html += ".btn-green{background:#4CAF50}";
    html += ".btn-blue{background:#2196F3}";
    html += ".btn-orange{background:#ff9800}";
    html += ".btn-red{background:#f44336}";
