    html += ".modal-content{background:#16213e;padding:30px;border-radius:10px;max-width:400px}";
    html += "</style>";
    html += "</head><body>";
    html += "<div class='container'>";
    html += "<div class='card'><h2>E-Reader Manager</h2>";
    html += "<button class='btn-green' onclick='showAddChapter()'>Add Chapter</button>";
    html += "<button onclick='location.reload()'>Refresh</button></div>";
    
    for (int i = 0; i < chapterCount; i++) {
      html += "<div class='card'>";
      html += "<h3>" + chapters[i] + "</h3>";
      html += "<button class='btn-blue' onclick='renameChapter(" + String(i) + ",\"" + chapters[i] + "\")'>Rename</button>";
      html += "<button class='btn-red' onclick='deleteChapter(" + String(i) + ",\"" + chapters[i] + "\")'>Delete</button>";
